          "raw": "{\n  \"name\": \"Escola Estadual Central\",\n  \"address\": \"Rua C, 500\",\n  \"neighborhood\": \"Centro\",\n  \"city\": \"Porto Alegre\",\n  \"contactPhone\": \"(51) 99999-2000\",\n  \"capacity\": 90,\n  \"occupied\": 30,\n  \"acceptsPets\": true\n}"
